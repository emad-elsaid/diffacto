#!/usr/bin/env bun
import {
  createCliRenderer,
  BoxRenderable,
  TextRenderable,
  DiffRenderable,
  ScrollBoxRenderable,
  type KeyEvent,
  t,
  fg,
} from "@opentui/core";
import { $ } from "bun";
import { parseArgs } from "util";
import { watch } from "fs";

// =============================================================================
// CLI Arguments
// =============================================================================

const HELP_TEXT = `
diffacto - A beautiful terminal UI for viewing git diffs

Usage: diffacto [options]

Options:
  -h, --help        Show this help message
  -s, --split       Start in split view mode (default: unified)
  -u, --unified     Start in unified view mode (default)
  -f, --follow      Enable follow mode - auto-scroll to changes (default)
  -F, --no-follow   Disable follow mode
  -c, --collapsed   Start with all file blocks collapsed
  -e, --expanded    Start with all file blocks expanded (default)

Keyboard Shortcuts:
  j/k, ↑/↓          Navigate between files
  Tab               Toggle current file block
  Shift+Tab         Toggle all file blocks
  1                 Switch to unified view
  2                 Switch to split view
  f                 Toggle follow mode
  q                 Quit
`.trim();

let args: Record<string, boolean>;
try {
  const parsed = parseArgs({
    args: Bun.argv.slice(2),
    options: {
      help: { type: "boolean", short: "h", default: false },
      split: { type: "boolean", short: "s", default: false },
      unified: { type: "boolean", short: "u", default: false },
      follow: { type: "boolean", short: "f", default: false },
      "no-follow": { type: "boolean", short: "F", default: false },
      collapsed: { type: "boolean", short: "c", default: false },
      expanded: { type: "boolean", short: "e", default: false },
    },
    strict: true,
    allowPositionals: false,
  });
  args = parsed.values as Record<string, boolean>;
} catch (e: any) {
  console.error(`Error: ${e.message}\nRun 'diffacto --help' for usage.`);
  process.exit(1);
}

if (args.help) {
  console.log(HELP_TEXT);
  process.exit(0);
}

const CONFIG = {
  diffViewMode: args.split ? "split" : "unified" as "unified" | "split",
  followMode: args["no-follow"] ? false : true,
  startCollapsed: args.collapsed ? true : false,
};

// =============================================================================
// Constants
// =============================================================================

const COLORS = {
  ADDED: "#00ff00",
  DELETED: "#ff0000",
  MODIFIED: "#ffff00",
  RENAMED: "#00bfff",
  MUTED: "#888888",
  HEADER_BG: "#1a1a1a",
  HEADER_BG_SELECTED: "#2a2a2a",
  FOOTER_BG: "#1a1a1a",
  FOOTER_FG: "#888888",
} as const;

const DIFF_COLORS = {
  ADDED_BG: "#d4f8d4",
  REMOVED_BG: "#fdd8d8",
  ADDED_SIGN: "#22c55e",
  REMOVED_SIGN: "#ef4444",
  LINE_NUMBER_FG: "#888888",
  CONTENT_FG: "#000000",
} as const;

const SYMBOLS = { ARROW_CLOSED: "▶", ARROW_OPEN: "▼" } as const;

const GIT_MARKERS = {
  DIFF_PREFIX: "diff --git ",
  NEW_FILE: "new file",
  DELETED_FILE: "deleted file",
  ADDITION_LINE: "+",
  DELETION_LINE: "-",
  ADDITION_HEADER: "+++",
  DELETION_HEADER: "---",
} as const;

const LAYOUT = {
  DIFF_CONTEXT_LINES: 3,
  HEADER_PADDING: [0, 1] as [number, number],
  BOX_PADDING_TOTAL: 2,
  PADDING_ADJUSTMENT: 1,
  EMPTY_STATE_PADDING: 2,
  MIN_PADDING: 1,
  FOOTER_HEIGHT: 1,
  FOOTER_PADDING: 1,
  WATCH_DEBOUNCE_MS: 500,
  RENAME_THRESHOLD: 0.6,
} as const;

// =============================================================================
// Types
// =============================================================================

interface FileDiff {
  filename: string;
  status: "modified" | "added" | "deleted" | "renamed";
  renamedFrom?: string;
  additions: number;
  deletions: number;
  rawDiff: string;
}

interface FileBlock {
  file: FileDiff;
  isOpen: boolean;
}

interface AppState {
  files: FileDiff[];
  blocks: FileBlock[];
  cursor: number;
  diffViewMode: "unified" | "split";
  followMode: boolean;
}

// =============================================================================
// Git Operations
// =============================================================================

function parseDiff(diffText: string): FileDiff[] {
  const files: FileDiff[] = [];
  const fileBlocks = diffText.split(new RegExp(`^${GIT_MARKERS.DIFF_PREFIX}`, "m")).filter(Boolean);

  for (const block of fileBlocks) {
    const fullBlock = GIT_MARKERS.DIFF_PREFIX + block;
    const lines = fullBlock.split("\n");
    const match = lines[0].match(/diff --git a\/(.*?) b\/(.*?)$/);
    if (!match) continue;

    let status: "modified" | "added" | "deleted" = "modified";
    let additions = 0;
    let deletions = 0;

    for (const line of lines) {
      if (line.startsWith(GIT_MARKERS.NEW_FILE)) status = "added";
      if (line.startsWith(GIT_MARKERS.DELETED_FILE)) status = "deleted";
      if (line.startsWith(GIT_MARKERS.ADDITION_LINE) && !line.startsWith(GIT_MARKERS.ADDITION_HEADER)) additions++;
      if (line.startsWith(GIT_MARKERS.DELETION_LINE) && !line.startsWith(GIT_MARKERS.DELETION_HEADER)) deletions++;
    }

    files.push({ filename: match[2], status, additions, deletions, rawDiff: fullBlock });
  }

  return files;
}

function contentLines(rawDiff: string): Set<string> {
  return new Set(
    rawDiff
      .split("\n")
      .filter((l) => (l.startsWith("+") || l.startsWith("-")) && !l.startsWith("+++") && !l.startsWith("---"))
      .map((l) => l.slice(1))
  );
}

function fileSimilarity(rawDiffA: string, rawDiffB: string): number {
  const a = contentLines(rawDiffA);
  const b = contentLines(rawDiffB);
  const intersection = [...a].filter((l) => b.has(l)).length;
  const union = a.size + b.size - intersection;
  return union === 0 ? 0 : intersection / union;
}

async function getRenamedDiff(delFilename: string, addFilename: string): Promise<string> {
  try {
    const oldContent = await $`git show HEAD:${delFilename}`.text();
    const tmpPath = `/tmp/_diffacto_old_${Date.now()}`;
    await Bun.write(tmpPath, oldContent);
    try {
      let diff = await $`git diff --no-index --unified=${LAYOUT.DIFF_CONTEXT_LINES} ${tmpPath} ${addFilename}`
        .nothrow()
        .text();
      return diff.replaceAll(tmpPath.slice(1), delFilename);
    } finally {
      await $`rm -f ${tmpPath}`.nothrow();
    }
  } catch {
    return "";
  }
}

async function detectRenames(files: FileDiff[]): Promise<FileDiff[]> {
  const deleted = files.filter((f) => f.status === "deleted");
  const added = files.filter((f) => f.status === "added");
  const renamedPairs = new Map<FileDiff, FileDiff>();
  const claimedAdded = new Set<FileDiff>();

  for (const del of deleted) {
    let bestScore = LAYOUT.RENAME_THRESHOLD;
    let bestMatch: FileDiff | null = null;
    for (const add of added) {
      if (claimedAdded.has(add)) continue;
      const score = fileSimilarity(del.rawDiff, add.rawDiff);
      if (score > bestScore) {
        bestScore = score;
        bestMatch = add;
      }
    }
    if (bestMatch) {
      renamedPairs.set(del, bestMatch);
      claimedAdded.add(bestMatch);
    }
  }

  if (renamedPairs.size === 0) return files;

  const suppressed = new Set<FileDiff>();
  const renamed: FileDiff[] = [];

  for (const [del, add] of renamedPairs) {
    suppressed.add(del);
    suppressed.add(add);
    const rawDiff = await getRenamedDiff(del.filename, add.filename);
    const parsed = rawDiff ? parseDiff(rawDiff)[0] : null;
    renamed.push({
      filename: add.filename,
      renamedFrom: del.filename,
      status: "renamed",
      additions: parsed?.additions ?? add.additions,
      deletions: parsed?.deletions ?? add.deletions,
      rawDiff: rawDiff || add.rawDiff,
    });
  }

  return [...files.filter((f) => !suppressed.has(f)), ...renamed];
}

async function getUntrackedDiffs(): Promise<FileDiff[]> {
  try {
    const statusOutput = await $`git status --porcelain`.text();
    const untracked = statusOutput
      .split("\n")
      .filter((line) => line.startsWith("?? "))
      .map((line) => line.slice(3).trim())
      .filter(Boolean);

    const results: FileDiff[] = [];
    for (const file of untracked) {
      const diffOutput = await $`git diff --no-index --unified=${LAYOUT.DIFF_CONTEXT_LINES} /dev/null ${file}`
        .nothrow()
        .text();
      if (diffOutput) results.push(...parseDiff(diffOutput));
    }
    return results;
  } catch {
    return [];
  }
}

async function getGitDiff(): Promise<FileDiff[]> {
  try {
    const [stagedOutput, unstagedOutput, untrackedFiles] = await Promise.all([
      $`git diff --cached --unified=${LAYOUT.DIFF_CONTEXT_LINES}`.text(),
      $`git diff --unified=${LAYOUT.DIFF_CONTEXT_LINES}`.text(),
      getUntrackedDiffs(),
    ]);

    const stagedFiles = stagedOutput ? parseDiff(stagedOutput) : [];
    const unstagedFiles = unstagedOutput ? parseDiff(unstagedOutput) : [];
    const fileMap = new Map<string, FileDiff>();

    for (const file of [...stagedFiles, ...unstagedFiles, ...untrackedFiles]) {
      const existing = fileMap.get(file.filename);
      if (existing) {
        existing.additions += file.additions;
        existing.deletions += file.deletions;
        existing.rawDiff += "\n" + file.rawDiff;
      } else {
        fileMap.set(file.filename, file);
      }
    }

    return await detectRenames(Array.from(fileMap.values()));
  } catch {
    return [];
  }
}

// =============================================================================
// UI Helpers
// =============================================================================

function getStatusColor(status: FileDiff["status"]): string {
  switch (status) {
    case "added":
      return COLORS.ADDED;
    case "deleted":
      return COLORS.DELETED;
    case "renamed":
      return COLORS.RENAMED;
    default:
      return COLORS.MODIFIED;
  }
}

function getFileLabel(file: FileDiff): string {
  return file.renamedFrom ? `${file.renamedFrom} → ${file.filename}` : file.filename;
}

// =============================================================================
// Main Application
// =============================================================================

async function main() {
  const renderer = await createCliRenderer({ exitOnCtrlC: true });
  const state: AppState = {
    files: await getGitDiff(),
    blocks: [],
    cursor: 0,
    diffViewMode: CONFIG.diffViewMode,
    followMode: CONFIG.followMode,
  };
  state.blocks = state.files.map((file) => ({ file, isOpen: !CONFIG.startCollapsed }));

  let scrollBox: ScrollBoxRenderable | null = null;
  let footer: BoxRenderable | null = null;
  let refreshTimeout: Timer | null = null;

  // ---------------------------------------------------------------------------
  // Rendering
  // ---------------------------------------------------------------------------

  function renderFileBlock(container: BoxRenderable, block: FileBlock, index: number) {
    const isCursor = index === state.cursor;
    const arrow = block.isOpen ? SYMBOLS.ARROW_OPEN : SYMBOLS.ARROW_CLOSED;
    const statusColor = getStatusColor(block.file.status);
    const headerBg = isCursor ? COLORS.HEADER_BG_SELECTED : COLORS.HEADER_BG;

    const fileLabel = getFileLabel(block.file);
    const leftPart = `${arrow} ${fileLabel}`;
    const additions = `+${block.file.additions}`;
    const deletions = `-${block.file.deletions}`;
    const statsText = `${additions} ${deletions}`;
    const padding = Math.max(
      LAYOUT.MIN_PADDING,
      renderer.width - LAYOUT.BOX_PADDING_TOTAL - leftPart.length - statsText.length
    ) + LAYOUT.PADDING_ADJUSTMENT;

    const headerBox = new BoxRenderable(renderer, {
      id: `header-${index}`,
      width: "100%",
      flexDirection: "row",
      backgroundColor: headerBg,
      padding: LAYOUT.HEADER_PADDING,
      onMouseDown: () => {
        state.cursor = index;
        state.blocks[index].isOpen = !state.blocks[index].isOpen;
        render();
      },
    });

    const headerText = new TextRenderable(renderer, {
      id: `text-${index}`,
      content: t`${fg(statusColor)(leftPart)}${" ".repeat(padding)}${fg(COLORS.ADDED)(additions)} ${fg(COLORS.DELETED)(deletions)}`,
    });

    headerBox.add(headerText);
    container.add(headerBox);

    if (block.isOpen) {
      const diffLines = block.file.rawDiff.split("\n").length;
      const diffView = new DiffRenderable(renderer, {
        id: `diff-${index}`,
        width: "100%",
        height: diffLines,
        diff: block.file.rawDiff,
        view: state.diffViewMode,
        showLineNumbers: true,
        syncScroll: true,
        fg: DIFF_COLORS.CONTENT_FG,
        addedBg: DIFF_COLORS.ADDED_BG,
        removedBg: DIFF_COLORS.REMOVED_BG,
        addedSignColor: DIFF_COLORS.ADDED_SIGN,
        removedSignColor: DIFF_COLORS.REMOVED_SIGN,
        lineNumberFg: DIFF_COLORS.LINE_NUMBER_FG,
        onMouseDown: () => {
          state.cursor = index;
          render();
        },
      });
      container.add(diffView);
    }
  }

  function renderFooter() {
    if (footer) footer.destroy();

    footer = new BoxRenderable(renderer, {
      id: "footer",
      width: "100%",
      height: LAYOUT.FOOTER_HEIGHT,
      backgroundColor: COLORS.FOOTER_BG,
      padding: [0, LAYOUT.FOOTER_PADDING],
      y: renderer.height - LAYOUT.FOOTER_HEIGHT,
    });

    const followIndicator = state.followMode ? fg(COLORS.ADDED)("FOLLOW") : fg(COLORS.MUTED)("follow");
    const footerText = new TextRenderable(renderer, {
      id: "footer-text",
      content: t`${fg(COLORS.FOOTER_FG)(" j/k: navigate  Tab: toggle  Shift+Tab: toggle all  1: unified  2: split  f: ")}${followIndicator}${fg(COLORS.FOOTER_FG)("  q: quit")}`,
    });

    footer.add(footerText);
    renderer.root.add(footer);
  }

  function render() {
    const prevScrollTop = scrollBox?.scrollTop ?? 0;
    if (scrollBox) scrollBox.destroy();

    const contentContainer = new BoxRenderable(renderer, {
      id: "content-container",
      width: "100%",
      flexDirection: "column",
    });

    for (let i = 0; i < state.blocks.length; i++) {
      renderFileBlock(contentContainer, state.blocks[i], i);
    }

    scrollBox = new ScrollBoxRenderable(renderer, {
      id: "scroll-container",
      width: "100%",
      height: renderer.height - LAYOUT.FOOTER_HEIGHT,
    });

    scrollBox.add(contentContainer);
    renderer.root.add(scrollBox);
    scrollBox.scrollTop = prevScrollTop;
    renderFooter();
  }

  // ---------------------------------------------------------------------------
  // State Updates
  // ---------------------------------------------------------------------------

  async function refreshDiff() {
    const newFiles = await getGitDiff();
    const oldState = new Map(state.blocks.map((b) => [b.file.filename, { rawDiff: b.file.rawDiff, isOpen: b.isOpen }]));
    const wasEmpty = state.files.length === 0;

    // Check if anything actually changed to avoid unnecessary re-renders
    if (state.files.length === newFiles.length && state.files.length > 0) {
      const allUnchanged = state.files.every((oldFile) => {
        const newFile = newFiles.find((f) => f.filename === oldFile.filename);
        return newFile && newFile.rawDiff === oldFile.rawDiff;
      });
      if (allUnchanged) return; // No changes detected, skip re-render
    }

    state.files = newFiles;
    state.blocks = newFiles.map((file) => ({
      file,
      isOpen: oldState.get(file.filename)?.isOpen ?? true,
    }));

    if (state.cursor >= state.blocks.length) {
      state.cursor = Math.max(0, state.blocks.length - 1);
    }

    const changedIndices = state.followMode
      ? newFiles.reduce<number[]>((acc, file, i) => {
          if (oldState.get(file.filename)?.rawDiff !== file.rawDiff) {
            state.blocks[i].isOpen = true;
            acc.push(i);
          }
          return acc;
        }, [])
      : [];

    // Clear existing UI elements when transitioning between empty and non-empty states
    if (wasEmpty && newFiles.length > 0) {
      // Transitioning from empty to non-empty state - destroy empty state container
      if (emptyContainer) {
        emptyContainer.destroy();
        emptyContainer = null;
      }
    } else if (!wasEmpty && newFiles.length === 0) {
      // Transitioning from non-empty to empty state - destroy scroll and footer
      if (scrollBox) {
        scrollBox.destroy();
        scrollBox = null;
      }
      if (footer) {
        footer.destroy();
        footer = null;
      }
    }

    if (newFiles.length === 0) {
      renderEmptyState();
    } else {
      render();
      if (state.followMode && changedIndices.length > 0 && scrollBox) {
        const lastIdx = changedIndices[changedIndices.length - 1];
        scrollBox.scrollChildIntoView(`header-${lastIdx}`);
        state.cursor = lastIdx;
      }
    }
  }

  // ---------------------------------------------------------------------------
  // Input Handling
  // ---------------------------------------------------------------------------

  const keyHandlers: Record<string, (key: KeyEvent) => void> = {
    q: () => {
      renderer.destroy();
      process.exit(0);
    },
    up: () => {
      state.cursor = Math.max(0, state.cursor - 1);
      render();
    },
    k: () => keyHandlers.up({} as KeyEvent),
    down: () => {
      state.cursor = Math.min(state.blocks.length - 1, state.cursor + 1);
      render();
    },
    j: () => keyHandlers.down({} as KeyEvent),
    tab: (key) => {
      if (key.shift) {
        const targetState = !state.blocks[state.cursor].isOpen;
        state.blocks.forEach((block) => (block.isOpen = targetState));
      } else {
        state.blocks[state.cursor].isOpen = !state.blocks[state.cursor].isOpen;
      }
      render();
    },
    "1": () => {
      state.diffViewMode = "unified";
      render();
    },
    "2": () => {
      state.diffViewMode = "split";
      render();
    },
    f: () => {
      state.followMode = !state.followMode;
      render();
    },
  };

  // ---------------------------------------------------------------------------
  // Initialization
  // ---------------------------------------------------------------------------

  let emptyContainer: BoxRenderable | null = null;

  function renderEmptyState() {
    // Clean up existing empty container if it exists
    if (emptyContainer) {
      emptyContainer.destroy();
    }

    emptyContainer = new BoxRenderable(renderer, {
      id: "empty",
      padding: LAYOUT.EMPTY_STATE_PADDING,
      flexDirection: "column",
    });
    const text = new TextRenderable(renderer, {
      id: "empty-text",
      content: "No changes to display",
      fg: COLORS.MUTED,
    });
    emptyContainer.add(text);
    renderer.root.add(emptyContainer);
  }

  if (state.files.length === 0) {
    renderEmptyState();
  } else {
    render();
  }

  renderer.keyInput.on("keypress", (key: KeyEvent) => {
    const handler = keyHandlers[key.name];
    if (handler) handler(key);
  });

  const watcher = watch(".", { recursive: true }, (event, filename) => {
    // Ignore changes in .git directory to reduce noise
    if (filename && (filename.startsWith('.git/') || filename.includes('/.git/'))) {
      return;
    }
    if (refreshTimeout) clearTimeout(refreshTimeout);
    refreshTimeout = setTimeout(refreshDiff, LAYOUT.WATCH_DEBOUNCE_MS);
  });

  process.on("beforeExit", () => watcher.close());
}

main();
